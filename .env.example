# Copy to `.env` or `.env.local` in the project root. Never commit those files.

# Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Storage bucket for optional PDF on create job (must match bucket id in Supabase).
# VITE_TRANSCRIPTS_BUCKET=job-transcripts

# Storage bucket for admin errata PDFs (must match bucket id in Supabase).
# VITE_ERRATA_BUCKET=job-errata

# Optional: UUID for public.users.role_id when the column is NOT NULL and has no DB default.
# VITE_DEFAULT_ROLE_ID=

# Supabase Edge Functions secret (set via `supabase secrets set`, not exposed to the browser).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# Supabase Edge Functions sender identity for Resend emails.
# RESEND_FROM_EMAIL=Depowl Legal <noreply@yourdomain.com>

# Optional Supabase Edge Functions secret when the errata bucket id differs from `job-errata`.
# ERRATA_BUCKET=job-errata

# Supabase Database Webhook shared secret for the `sendErrataReadyEmail` Edge Function.
# ERRATA_WEBHOOK_SECRET=replace-with-a-long-random-string
